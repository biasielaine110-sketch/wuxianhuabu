{
  "name": "ai",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspace=ai-frontend",
    "dev-frontend": "npm run dev --prefix frontend",
    "dev-backend": "npm run dev --prefix backend",
    "dev": "npm run dev-frontend",
    "dev:vertex": "concurrently -n web,api -c cyan,green \"npm run dev-frontend\" \"npm run dev-backend\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "latest"
  }
}
