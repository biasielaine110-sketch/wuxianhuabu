{
  "name": "ai-api-backend-server",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "description": "Node backend for proxying Google Cloud API requests",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file=.env.local server.js",
    "start:prod": "node server.js",
    "dev": "nodemon --env-file=.env.local server.js",
    "start:doubao": "node doubao-proxy-server.js",
    "dev:doubao": "nodemon doubao-proxy-server.js",
    "start:video-proxy": "node doubao-proxy-server.js",
    "dev:video-proxy": "nodemon doubao-proxy-server.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.5.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.59.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "nodemon": "^3.1.11"
  }
}
